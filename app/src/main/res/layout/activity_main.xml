<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- TODO: Update blank fragment layout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContentGroup"
        android:layout_width="0dp"
        android:layout_height="0dp"
    android:visibility="gone"
app:layout_constraintTop_toTopOf="parent"
app:layout_constraintBottom_toBottomOf="parent"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintEnd_toEndOf="parent">
<TextView
    android:id="@+id/currentTempText"
    android:layout_width="269dp"
    android:layout_height="170dp"
    android:fontFamily="@font/outfit_bold"
    android:gravity="center"
    android:text=""
    android:textColor="@color/dark_blue"
    android:textSize="140dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintHorizontal_bias="0.542"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_bias="0.285"
    tools:ignore="MissingConstraints" />




<TextView
    android:id="@+id/currentTempTextMIN"
    android:layout_width="60dp"
    android:layout_height="60dp"
    android:fontFamily="@font/outfit_bold"
    android:gravity="center"
    android:text=""
    android:textColor="@color/dark_blue"
    android:textSize="30sp"
    app:layout_constraintBottom_toBottomOf="@+id/currentTempText"
    app:layout_constraintEnd_toStartOf="@+id/currentTempText"
    app:layout_constraintHorizontal_bias="0.562"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="@+id/currentTempText"
    app:layout_constraintVertical_bias="0.99"
    tools:ignore="MissingConstraints" />


<TextView
    android:id="@+id/currentTempTextMAX"
    android:layout_width="60dp"
    android:layout_height="60dp"
    android:fontFamily="@font/outfit_bold"
    android:gravity="center"
    android:text=""
    android:textColor="@color/dark_blue"
    android:textSize="30sp"
    app:layout_constraintBottom_toBottomOf="@+id/currentTempText"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintHorizontal_bias="0.508"
    app:layout_constraintStart_toEndOf="@+id/currentTempText"
    app:layout_constraintTop_toTopOf="@+id/currentTempText"
    app:layout_constraintVertical_bias="1.0"
    tools:ignore="MissingConstraints" />

<TextView
    android:id="@+id/WelcomeText"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fontFamily="@font/inter_extrabold"
    android:text=""
    android:textColor="@color/dark_blue"
    android:textSize="40sp"
    app:layout_constraintBottom_toTopOf="@+id/currentTempText"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintHorizontal_bias="0.195"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_bias="0.542" />

    <TextView
        android:id="@+id/counterTextView"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:alpha="0"
        android:background="@drawable/background_rounded_fornew"
        android:fontFamily="@font/inter_medium"
        android:layout_marginHorizontal="12dp"
        android:gravity="top|center_horizontal"
        android:padding="12dp"
        android:text=""
        android:textColor="@color/white_blue"
        android:textSize="12sp"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@+id/clothingAdviceText"

        app:layout_constraintEnd_toEndOf="@+id/clothingAdviceText"
        app:layout_constraintHorizontal_bias="0.257"
        app:layout_constraintStart_toStartOf="@+id/clothingAdviceText"
        app:layout_constraintTop_toTopOf="@+id/clothingAdviceText"
        app:layout_constraintVertical_bias="0.54" />

    <TextView
        android:id="@+id/clothingAdviceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_rounded"
        android:drawableStart="@drawable/baseline_auto_awesome_24"
        android:drawablePadding="12dp"
        android:layout_marginHorizontal="12dp"
        android:fontFamily="@font/inter_bold"
        android:gravity="center_vertical|start"

        android:padding="16dp"
        android:paddingEnd="50dp"
        android:text=""

        android:textSize="22sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.47"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/currentTempText"
        app:layout_constraintVertical_bias="0.192"
        app:layout_constraintWidth_percent="0.85" />

<ImageButton
    android:id="@+id/myImageButton"
    android:layout_width="60dp"
    android:layout_height="60dp"
    android:layout_gravity="center"
    android:background="@drawable/my_animation"
    app:layout_constraintBottom_toBottomOf="@+id/clothingAdviceText"
    app:layout_constraintEnd_toEndOf="@+id/clothingAdviceText"
    app:layout_constraintTop_toTopOf="@+id/clothingAdviceText" />



<TextView
    android:id="@+id/carText"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/background_rounded"
    android:drawableStart="@drawable/outline_directions_car_24"
    android:drawablePadding="8dp"
    android:layout_marginHorizontal="12dp"
    android:fontFamily="@font/inter_bold"
    android:gravity="center_vertical|start"

    android:padding="16dp"
    android:text=""
    android:textColor="@color/dark_blue"
    android:textSize="22sp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintHorizontal_bias="0.47"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/clothingAdviceText"
    app:layout_constraintVertical_bias="0.075"
    app:layout_constraintWidth_percent="0.85" />

<Button
    android:id="@+id/notification_arrow_button"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_marginHorizontal="12dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:stateListAnimator="@null"
    app:elevation="0dp"
    android:text="Расписание уведомлений"
    app:rippleColor="?attr/colorControlHighlight"
    android:textColor="@color/dark_blue"
    android:background="@drawable/button_custom_ripple_background"
    android:textSize="22sp"
    android:textAllCaps="false"
    android:fontFamily="@font/inter_bold"
    android:gravity="center_vertical|start"
    android:drawableEnd="@drawable/outline_chevron_right_24"
    app:tint="@color/dark_blue"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintHorizontal_bias="0.47"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/carText"
    app:layout_constraintVertical_bias="0.120"
    app:layout_constraintWidth_percent="0.85" />





</androidx.constraintlayout.widget.ConstraintLayout>

<ImageView
    android:id="@+id/loadingAnimationView"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:background="@drawable/my_animation_loud" />


</androidx.constraintlayout.widget.ConstraintLayout>