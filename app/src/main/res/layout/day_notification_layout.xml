<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dayRootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="1dp"
    android:layout_marginEnd="1dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/background_rounded"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="15dp">

    <!-- TextView for the day of the week -->
    <TextView
        android:id="@+id/dayTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/inter_bold"
        android:text="Понедельник"
        android:textColor="@color/dark_blue"
        android:textSize="20sp" />

    <!-- TextView to display the selected time -->
    <TextView
        android:id="@+id/daytime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/inter_bold"
        android:textColor="@color/dark_blue"
        android:textSize="20sp"
        android:text="" />

    <!-- ImageButton to add or delete the time -->
    <ImageButton
        android:id="@+id/addTimeButton"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:background="@drawable/background_rounded_fornew"
        android:padding="4dp"
        android:scaleType="centerInside"
        app:srcCompat="@drawable/rounded_add_24" />

</LinearLayout>